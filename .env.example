# Alpaca Paper Trading (get keys from https://app.alpaca.markets/)
ALPACA_API_KEY=your_paper_api_key
ALPACA_SECRET_KEY=your_paper_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Market data feed: iex (free) or sip (paid) — used for live Alpaca stream only
ALPACA_DATA_FEED=iex

# Research uses Yahoo Finance (yfinance) by default — see config/settings.yaml research section
# No API key required for Yahoo. Alpaca keys are still required for trading and live quotes.

# Ollama (local fallback)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=phi4-mini

# OpenRouter (primary when LLM_PRIMARY_PROVIDER=openrouter — get key at https://openrouter.ai/keys)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Primary model. Nemotron 3 Ultra is a free frontier reasoning model.
OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
# Comma-separated server-side fallback models (tried in order if primary errors/429s)
OPENROUTER_FALLBACK_MODELS=
# Thinking toggle: false = fast, clean JSON (recommended); true = deeper reasoning, slower
OPENROUTER_REASONING=false

# Google AI Studio (primary when GOOGLE_API_KEY is set — get key at https://aistudio.google.com/apikey)
GOOGLE_API_KEY=
GOOGLE_MODEL=gemma-4-31b-it
# Thinking level for Gemma 4 / Gemini: MINIMAL | LOW | MEDIUM | HIGH
# Use off/none/disabled to omit thinkingConfig (e.g. gemini-2.5-flash-lite)
GOOGLE_THINKING_LEVEL=MINIMAL
# Optional: max requests per minute (free tier is often 12–15)
GOOGLE_RPM_LIMIT=12
# Optional: force provider — auto | openrouter | google | ollama
# (auto prefers OpenRouter when configured, then Google, then Ollama)
LLM_PRIMARY_PROVIDER=auto

# OpenClaw gateway (fallback LLM + alerts)
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_MODEL=gemma4:cloud
OPENCLAW_ALERT_CHANNEL=telegram

# Optional: webhook URL for alerts if not using OpenClaw channels
ALERT_WEBHOOK_URL=

# Optional: Finnhub earnings calendar for screener
FINNHUB_API_KEY=

# Admin portal — set a strong secret; required for /api/admin/* writes
ADMIN_API_KEY=
